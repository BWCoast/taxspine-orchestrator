__pycache__
*.pyc
*.pyo
.pytest_cache
*.egg-info
.git
.gitignore
.github

# Persistent data — never bake runtime data into the image
data/
*.db

# Scratch files
gains.csv
prices.csv
events.json
test-orchestrator.py
test-full-stack.py

