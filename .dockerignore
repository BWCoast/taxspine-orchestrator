dashboard/
ui.html

# Test suite — not needed at runtime
tests/

# Option B vendor dir — populated at build time by build-local.ps1, then removed.
# Listed here so it's excluded from Option A (Dockerfile) builds.
# Dockerfile.local explicitly COPY vendor/tax-nor/, which overrides this.
vendor/
