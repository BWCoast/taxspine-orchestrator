#!/usr/bin/env bash
# .githooks/pre-push — pre-push safety checks for taxspine-orchestrator
#
# Install:  git config core.hooksPath .githooks
# Run manually: bash .githooks/pre-push
#
# Checks:
#   1. requirements.lock has no forbidden/polluted packages
#   2. docker.yml and Dockerfile are not diverged from HEAD (uncommitted local edits)
#   3. TAILWIND_VERSION in Dockerfile matches an existing GitHub Release
#   4. Lockfile header date is not stale (warn if > 30 days old)
#
# Exit code: 0 = all clear, 1 = one or more failures

set -euo pipefail

RED='\033[0;31m'
YEL='\033[1;33m'
GRN='\033[0;32m'
NC='\033[0m'

PASS=0
FAIL=0
WARN=0

ok()   { echo -e "  ${GRN}✓${NC} $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; FAIL=$((FAIL+1)); }
warn() { echo -e "  ${YEL}!${NC} $*"; WARN=$((WARN+1)); }

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Pre-push checklist  (docs/CI_BUILD_GOTCHAS.md)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── §1: Forbidden packages in requirements.lock ──────────────────────────────
echo ""
echo "§1  requirements.lock — forbidden packages"

FORBIDDEN=(
  "hf-xet"
  "huggingface_hub"
  "huggingface-hub"
  "weasyprint"
  "zopfli"
  "hypothesis"
)
# NOTE: annotated-doc IS legitimate — it is a real fastapi transitive dep (by tiangolo).
# Do not add it to the forbidden list.

if [ ! -f "requirements.lock" ]; then
  fail "requirements.lock not found"
else
  ALL_CLEAN=true
  for pkg in "${FORBIDDEN[@]}"; do
    # case-insensitive match on the package name portion (before ==)
    if grep -qi "^${pkg}==" requirements.lock; then
      fail "Forbidden package in lockfile: $(grep -i "^${pkg}==" requirements.lock)"
      ALL_CLEAN=false
    fi
  done
  if $ALL_CLEAN; then
    ok "No forbidden packages found in requirements.lock"
  fi
fi

# ── §2: Lockfile header date staleness ───────────────────────────────────────
echo ""
echo "§2  requirements.lock — freshness"

if [ -f "requirements.lock" ]; then
  HEADER_DATE=$(grep "Generated:" requirements.lock | head -1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' || true)
  if [ -z "$HEADER_DATE" ]; then
    warn "Could not parse 'Generated:' date from requirements.lock header"
  else
    # Days since generation (portable across Linux/macOS)
    GEN_EPOCH=$(date -d "$HEADER_DATE" +%s 2>/dev/null || date -j -f "%Y-%m-%d" "$HEADER_DATE" +%s 2>/dev/null || echo 0)
    NOW_EPOCH=$(date +%s)
    DAYS_OLD=$(( (NOW_EPOCH - GEN_EPOCH) / 86400 ))
    if [ "$DAYS_OLD" -gt 30 ]; then
      warn "requirements.lock is ${DAYS_OLD} days old (generated ${HEADER_DATE}) — consider regenerating from a clean venv"
    else
      ok "requirements.lock generated ${HEADER_DATE} (${DAYS_OLD} days ago)"
    fi
  fi
fi

# ── §3: docker.yml / Dockerfile not diverged from HEAD ───────────────────────
echo ""
echo "§3  Infra files — no uncommitted divergence"

INFRA_FILES=(
  ".github/workflows/docker.yml"
  "Dockerfile"
)

for f in "${INFRA_FILES[@]}"; do
  if [ ! -f "$f" ]; then
    warn "$f not found"
    continue
  fi
  DIFF_LINES=$(git diff HEAD -- "$f" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$DIFF_LINES" -gt 0 ]; then
    fail "$f has ${DIFF_LINES} uncommitted diff lines — commit infra changes before pushing (see §3 in CI_BUILD_GOTCHAS.md)"
  else
    ok "$f is clean (matches HEAD)"
  fi
done

# ── §4: TAILWIND_VERSION exists in Dockerfile ────────────────────────────────
echo ""
echo "§4  Tailwind CLI version"

if [ -f "Dockerfile" ]; then
  TW_VER=$(grep -oE 'TAILWIND_VERSION=[0-9]+\.[0-9]+\.[0-9]+' Dockerfile | head -1 | cut -d= -f2 || true)
  if [ -z "$TW_VER" ]; then
    warn "Could not parse TAILWIND_VERSION from Dockerfile"
  else
    ok "TAILWIND_VERSION=${TW_VER} (verify manually: https://github.com/tailwindlabs/tailwindcss/releases/tag/v${TW_VER})"
  fi
else
  warn "Dockerfile not found — skipping Tailwind check"
fi

# ── §5: At least one test passes (smoke) ─────────────────────────────────────
echo ""
echo "§5  Quick smoke test (1 test)"

if python -m pytest tests/ -q --co -n0 2>/dev/null | grep -q "test session starts" 2>/dev/null; then
  ok "Test collection succeeds"
else
  # fallback: just check pytest is importable
  if python -m pytest --version 2>/dev/null | grep -q "pytest"; then
    ok "pytest is available (collection check skipped)"
  else
    warn "Could not verify pytest — run 'python -m pytest' manually before push"
  fi
fi

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ "$FAIL" -gt 0 ]; then
  echo -e "  ${RED}BLOCKED — ${FAIL} check(s) failed.${NC} Fix before pushing."
  echo "  See docs/CI_BUILD_GOTCHAS.md for remediation steps."
  echo ""
  exit 1
elif [ "$WARN" -gt 0 ]; then
  echo -e "  ${YEL}WARNINGS — ${WARN} item(s) need manual review.${NC}"
  echo "  Push is allowed but review the warnings above."
  echo ""
  exit 0
else
  echo -e "  ${GRN}ALL CLEAR — safe to push.${NC}"
  echo ""
  exit 0
fi
