# ── taxspine-orchestrator environment variables ──────────────────────────────
#
# Copy this file to .env and fill in values appropriate for your deployment.
# Never commit .env to version control.
#
# Usage (uvicorn):
#   cp .env.example .env
#   # edit .env
#   uvicorn taxspine_orchestrator.main:app --env-file .env
#
# Usage (Docker Compose):
#   env_file:
#     - .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Security (INFRA-17) ───────────────────────────────────────────────────────

# REQUIRED in any network-reachable deployment.
# If empty, all API endpoints are publicly accessible with no authentication.
# Generate a strong random value: python -c "import secrets; print(secrets.token_urlsafe(32))"
ORCHESTRATOR_KEY=

# Comma-separated list of allowed CORS origins (no trailing slash).
# Add your UI origin(s) here.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000


# ── Storage paths ─────────────────────────────────────────────────────────────

# All paths must be absolute.  Defaults shown below are for local Windows dev.
# Override for Linux/container deployments.

# Temporary working files.
# TEMP_DIR=/var/lib/taxspine/tmp

# Tax report output files (HTML, CSV, RF-1159 JSON).
# OUTPUT_DIR=/var/lib/taxspine/output

# Uploaded CSV files (exchange transaction exports).
# UPLOAD_DIR=/var/lib/taxspine/uploads

# Persistent state: jobs.db, workspace.json.
# DATA_DIR=/var/lib/taxspine/data

# Cached price CSVs (Norges Bank / Kraken).
# PRICES_DIR=/var/lib/taxspine/prices

# SQLite database for FIFO lot carry-forward between tax years.
# LOT_STORE_DB=/var/lib/taxspine/data/lots.db

# SQLite databases for per-source event deduplication.
# DEDUP_DIR=/var/lib/taxspine/data/dedup


# ── CLI binary paths (override if not on PATH) ───────────────────────────────

# TAXSPINE_XRPL_NOR_CLI=taxspine-xrpl-nor
# TAXSPINE_NOR_REPORT_CLI=taxspine-nor-report
# TAXSPINE_NOR_MULTI_CLI=taxspine-nor-multi
# TAXSPINE_UK_REPORT_CLI=taxspine-uk-report
